        <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
          <data line="0" column="0" value="0"/>
        </ScilabInteger>
        <ScilabDouble as="state" height="0" width="0"/>
        <ScilabDouble as="dState" height="0" width="0"/>
        <Array as="oDState" scilabClass="ScilabList"/>
        <Array as="equations" scilabClass="ScilabList"/>
        <mxGeometry as="geometry" x="700.0" y="420.0" width="40.0" height="40.0"/>
      </BasicBlock>
      <ControlPort id="BAR1_ctrl" parent="BAR1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ControlPort;align=center;verticalAlign=top;spacing=10.0" value=""/>
      <ExplicitInputPort id="BAR1_in1" parent="BAR1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="-1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>
      <ExplicitInputPort id="BAR1_in2" parent="BAR1" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="-1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>

      <!-- CLOCK_c: periodic clock, triggers all scopes -->
      <BasicBlock id="CLK1" parent="0:2:0" interfaceFunctionName="CLOCK_c" blockType="h" dependsOnU="0" dependsOnT="0" simulationFunctionName="csuper" simulationFunctionType="DEFAULT" style="CLOCK_c">
        <ScilabDouble as="exprs" height="0" width="0"/>
        <ScilabDouble as="realParameters" height="0" width="0"/>
        <ScilabDouble as="integerParameters" height="0" width="0"/>
        <Array as="objectsParameters" scilabClass="ScilabList"/>
        <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
          <data line="0" column="0" value="0"/>
        </ScilabInteger>
        <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
          <data line="0" column="0" value="0"/>
        </ScilabInteger>
        <ScilabDouble as="state" height="0" width="0"/>
        <ScilabDouble as="dState" height="0" width="0"/>
        <Array as="oDState" scilabClass="ScilabList"/>
        <Array as="equations" scilabClass="ScilabList"/>
        <mxGeometry as="geometry" x="820.0" y="50.0" width="40.0" height="40.0"/>
        <SuperBlockDiagram as="child" background="-1" gridEnabled="1" title="">
          <Array as="context" scilabClass="String[]"></Array>
          <mxGraphModel as="model">
            <root>
              <mxCell id="CLK1_sub0"/>
              <mxCell id="CLK1_sub_parent" parent="CLK1_sub0"/>
              <EventOutBlock id="CLK1_out_blk" parent="CLK1_sub_parent" interfaceFunctionName="CLKOUT_f" blockType="d" dependsOnU="0" dependsOnT="0" simulationFunctionName="output" simulationFunctionType="DEFAULT" style="">
                <ScilabString as="exprs" height="1" width="1">
                  <data line="0" column="0" value="1"/>
                </ScilabString>
                <ScilabDouble as="realParameters" height="0" width="0"/>
                <ScilabInteger as="integerParameters" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="1"/>
                </ScilabInteger>
                <Array as="objectsParameters" scilabClass="ScilabList"/>
                <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabDouble as="state" height="0" width="0"/>
                <ScilabDouble as="dState" height="0" width="0"/>
                <Array as="oDState" scilabClass="ScilabList"/>
                <Array as="equations" scilabClass="ScilabList"/>
                <mxGeometry as="geometry" x="399.0" y="162.0" width="20.0" height="20.0"/>
              </EventOutBlock>
              <ControlPort id="CLK1_out_blk_ctrl" parent="CLK1_out_blk" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="" value=""/>
              <BasicBlock id="CLK1_evtdly" parent="CLK1_sub_parent" interfaceFunctionName="EVTDLY_c" blockType="d" dependsOnU="0" dependsOnT="0" simulationFunctionName="evtdly4" simulationFunctionType="C_OR_FORTRAN" style="">
                <ScilabString as="exprs" height="2" width="1">
                  <data line="0" column="0" value="0.1"/>
                  <data line="1" column="0" value="0.1"/>
                </ScilabString>
                <ScilabDouble as="realParameters" height="1" width="2">
                  <data line="0" column="0" realPart="0.1"/>
                  <data line="0" column="1" realPart="0.1"/>
                </ScilabDouble>
                <ScilabDouble as="integerParameters" height="0" width="0"/>
                <Array as="objectsParameters" scilabClass="ScilabList"/>
                <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabDouble as="state" height="0" width="0"/>
                <ScilabDouble as="dState" height="0" width="0"/>
                <Array as="oDState" scilabClass="ScilabList"/>
                <Array as="equations" scilabClass="ScilabList"/>
                <mxGeometry as="geometry" x="320.0" y="232.0" width="40.0" height="40.0"/>
              </BasicBlock>
              <ControlPort id="CLK1_evtdly_ctrl" parent="CLK1_evtdly" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="" value=""/>
              <CommandPort id="CLK1_evtdly_cmd" parent="CLK1_evtdly" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.1" style="" value=""/>
              <SplitBlock id="CLK1_split" parent="CLK1_sub_parent" interfaceFunctionName="CLKSPLIT_f" blockType="d" dependsOnU="0" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="">
                <ScilabDouble as="exprs" height="0" width="0"/>
                <ScilabDouble as="realParameters" height="0" width="0"/>
                <ScilabDouble as="integerParameters" height="0" width="0"/>
                <Array as="objectsParameters" scilabClass="ScilabList"/>
                <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
                  <data line="0" column="0" value="0"/>
                </ScilabInteger>
                <ScilabDouble as="state" height="0" width="0"/>
                <ScilabDouble as="dState" height="0" width="0"/>
                <Array as="oDState" scilabClass="ScilabList"/>
                <Array as="equations" scilabClass="ScilabList"/>
                <mxGeometry as="geometry" x="380.71066" y="172.0" width="0.3333333333333333" height="0.3333333333333333"/>
              </SplitBlock>
              <ControlPort id="CLK1_split_ctrl" parent="CLK1_split" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="" value=""/>
              <CommandPort id="CLK1_split_cmd1" parent="CLK1_split" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="-1.0" style="" value=""/>
              <CommandPort id="CLK1_split_cmd2" parent="CLK1_split" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="-1.0" style="" value=""/>
              <CommandControlLink id="CLK1_lnk1" parent="CLK1_sub_parent" source="CLK1_evtdly_cmd" target="CLK1_split_ctrl" style="" value="">
                <mxGeometry as="geometry">
                  <mxPoint as="sourcePoint" x="340.0" y="226.29"/>
                  <Array as="points">
                    <mxPoint x="340.0" y="172.0"/>
                  </Array>
                  <mxPoint as="targetPoint" x="380.71" y="172.0"/>
                </mxGeometry>
              </CommandControlLink>
              <CommandControlLink id="CLK1_lnk2" parent="CLK1_sub_parent" source="CLK1_split_cmd1" target="CLK1_out_blk_ctrl" style="" value="">
                <mxGeometry as="geometry">
                  <mxPoint as="sourcePoint" x="380.71" y="172.0"/>
                  <Array as="points"></Array>
                  <mxPoint as="targetPoint" x="399.0" y="172.0"/>
                </mxGeometry>
              </CommandControlLink>
              <CommandControlLink id="CLK1_lnk3" parent="CLK1_sub_parent" source="CLK1_split_cmd2" target="CLK1_evtdly_ctrl" style="" value="">
                <mxGeometry as="geometry">
                  <mxPoint as="sourcePoint" x="380.71" y="172.0"/>
                  <Array as="points">
                    <mxPoint x="380.71" y="302.0"/>
                    <mxPoint x="340.0" y="302.0"/>
                  </Array>
                  <mxPoint as="targetPoint" x="340.0" y="277.71"/>
                </mxGeometry>
              </CommandControlLink>
            </root>
          </mxGraphModel>
          <mxCell as="defaultParent" id="CLK1_sub_parent" parent="CLK1_sub0"/>
        </SuperBlockDiagram>
      </BasicBlock>
      <CommandPort id="CLK1_cmd" parent="CLK1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="-1.0" style="CommandPort;align=center;verticalAlign=bottom;spacing=10.0" value=""/>

      
      <!-- Link 1: GAIN1_out → INT1_in (theta_ddot → integrator 1) -->
      <ExplicitLink id="lnk_G1_I1" parent="0:2:0" source="GAIN1_out" target="INT1_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="140.0" y="220.0"/>
          <Array as="points"></Array>
          <mxPoint as="targetPoint" x="220.0" y="220.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 2: INT1_out → INT2_in (theta_dot → integrator 2) -->
      <ExplicitLink id="lnk_I1_I2" parent="0:2:0" source="INT1_out" target="INT2_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="260.0" y="220.0"/>
          <Array as="points"></Array>
          <mxPoint as="targetPoint" x="340.0" y="220.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 3: INT2_out → SIN1_in (theta → sin) -->
      <ExplicitLink id="lnk_I2_SIN" parent="0:2:0" source="INT2_out" target="SIN1_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="380.0" y="220.0"/>
          <Array as="points"></Array>
          <mxPoint as="targetPoint" x="460.0" y="220.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 4: SIN1_out → GAIN1_in (sin(theta) feedback to gain -5) -->
      <ExplicitLink id="lnk_SIN_G1" parent="0:2:0" source="SIN1_out" target="GAIN1_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="540.0" y="220.0"/>
            <mxPoint x="540.0" y="270.0"/>
            <mxPoint x="80.0" y="270.0"/>
            <mxPoint x="80.0" y="220.0"/>
          </Array>
          <mxPoint as="targetPoint" x="100.0" y="220.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 5: INT2_out → COS1_in (theta → cos for animation) -->
      <ExplicitLink id="lnk_I2_COS" parent="0:2:0" source="INT2_out" target="COS1_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="380.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="420.0" y="220.0"/>
            <mxPoint x="420.0" y="330.0"/>
          </Array>
          <mxPoint as="targetPoint" x="460.0" y="330.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 6: INT1_out → GAIN2_in (theta_dot to scope branch) -->
      <ExplicitLink id="lnk_I1_G2" parent="0:2:0" source="INT1_out" target="GAIN2_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="260.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="300.0" y="220.0"/>
            <mxPoint x="300.0" y="120.0"/>
          </Array>
          <mxPoint as="targetPoint" x="460.0" y="120.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 7: INT2_out → GAIN3_in (theta to scope branch) -->
      <ExplicitLink id="lnk_I2_G3" parent="0:2:0" source="INT2_out" target="GAIN3_in" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="380.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="410.0" y="220.0"/>
            <mxPoint x="410.0" y="440.0"/>
          </Array>
          <mxPoint as="targetPoint" x="460.0" y="440.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 8: GAIN2_out → MUX2_in1 (theta_dot → MUX2 port 1) -->
      <ExplicitLink id="lnk_G2_MUX2" parent="0:2:0" source="GAIN2_out" target="MUX2_in1" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="120.0"/>
          <Array as="points">
            <mxPoint x="550.0" y="120.0"/>
            <mxPoint x="550.0" y="198.0"/>
          </Array>
          <mxPoint as="targetPoint" x="580.0" y="198.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 9: GAIN3_out → MUX2_in2 (theta → MUX2 port 2) -->
      <ExplicitLink id="lnk_G3_MUX2" parent="0:2:0" source="GAIN3_out" target="MUX2_in2" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="440.0"/>
          <Array as="points">
            <mxPoint x="560.0" y="440.0"/>
            <mxPoint x="560.0" y="212.0"/>
          </Array>
          <mxPoint as="targetPoint" x="580.0" y="212.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 10: SIN1_out → MUX1_in1 (sin(theta) → MUX1 port 1) -->
      <ExplicitLink id="lnk_SIN_MUX1" parent="0:2:0" source="SIN1_out" target="MUX1_in1" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="542.0" y="220.0"/>
            <mxPoint x="542.0" y="308.0"/>
          </Array>
          <mxPoint as="targetPoint" x="580.0" y="308.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 11: COS1_out → MUX1_in2 (cos(theta) → MUX1 port 2) -->
      <ExplicitLink id="lnk_COS_MUX1" parent="0:2:0" source="COS1_out" target="MUX1_in2" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="330.0"/>
          <Array as="points"></Array>
          <mxPoint as="targetPoint" x="580.0" y="322.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 12: MUX2_out → SCOPE1_in1+in2 — CMSCOPE takes 2 separate inputs, not MUX -->
      <!-- Actually CMSCOPE has 2 explicit inputs; connect theta_dot and theta directly -->
      <!-- Re-route: GAIN2_out → SCOPE1_in1, GAIN3_out → SCOPE1_in2 -->
      <ExplicitLink id="lnk_MUX2_SCOPE" parent="0:2:0" source="MUX2_out" target="SCOPE1_in1" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="590.0" y="205.0"/>
          <Array as="points"></Array>
          <mxPoint as="targetPoint" x="700.0" y="198.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 13: MUX1_out → ANIM1_in1 (sin(theta) to CANIMXY port 1) -->
      <!-- CANIMXY has 2 separate inputs; connect sin(theta) and cos(theta) separately -->
      <ExplicitLink id="lnk_SIN_ANIM" parent="0:2:0" source="SIN1_out" target="ANIM1_in1" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="544.0" y="220.0"/>
            <mxPoint x="544.0" y="308.0"/>
            <mxPoint x="660.0" y="308.0"/>
          </Array>
          <mxPoint as="targetPoint" x="700.0" y="308.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 14: COS1_out → ANIM1_in2 (cos(theta) to CANIMXY port 2) -->
      <ExplicitLink id="lnk_COS_ANIM" parent="0:2:0" source="COS1_out" target="ANIM1_in2" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="330.0"/>
          <Array as="points">
            <mxPoint x="660.0" y="330.0"/>
          </Array>
          <mxPoint as="targetPoint" x="700.0" y="322.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 15: SIN1_out → BAR1_in1 -->
      <ExplicitLink id="lnk_SIN_BAR" parent="0:2:0" source="SIN1_out" target="BAR1_in1" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="220.0"/>
          <Array as="points">
            <mxPoint x="546.0" y="220.0"/>
            <mxPoint x="546.0" y="433.0"/>
            <mxPoint x="660.0" y="433.0"/>
          </Array>
          <mxPoint as="targetPoint" x="700.0" y="433.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 16: COS1_out → BAR1_in2 -->
      <ExplicitLink id="lnk_COS_BAR" parent="0:2:0" source="COS1_out" target="BAR1_in2" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="330.0"/>
          <Array as="points">
            <mxPoint x="548.0" y="330.0"/>
            <mxPoint x="548.0" y="447.0"/>
            <mxPoint x="660.0" y="447.0"/>
          </Array>
          <mxPoint as="targetPoint" x="700.0" y="447.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- Link 17: CLK1_cmd → SCOPE1_ctrl (clock event → CMSCOPE control) -->
      <CommandControlLink id="lnk_CLK_SCOPE" parent="0:2:0" source="CLK1_cmd" target="SCOPE1_ctrl" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="840.0" y="90.0"/>
          <Array as="points">
            <mxPoint x="840.0" y="150.0"/>
            <mxPoint x="720.0" y="150.0"/>
          </Array>
          <mxPoint as="targetPoint" x="720.0" y="185.0"/>
        </mxGeometry>
      </CommandControlLink>

      <!-- Link 18: CLK1_cmd → ANIM1_ctrl (clock event → CANIMXY control) -->
      <CommandControlLink id="lnk_CLK_ANIM" parent="0:2:0" source="CLK1_cmd" target="ANIM1_ctrl" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="840.0" y="90.0"/>
          <Array as="points">
            <mxPoint x="840.0" y="160.0"/>
            <mxPoint x="730.0" y="160.0"/>
            <mxPoint x="730.0" y="280.0"/>
            <mxPoint x="720.0" y="280.0"/>
          </Array>
          <mxPoint as="targetPoint" x="720.0" y="295.0"/>
        </mxGeometry>
      </CommandControlLink>

      <!-- Link 19: CLK1_cmd → BAR1_ctrl (clock event → BARXY control) -->
      <CommandControlLink id="lnk_CLK_BAR" parent="0:2:0" source="CLK1_cmd" target="BAR1_ctrl" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="840.0" y="90.0"/>
          <Array as="points">
            <mxPoint x="840.0" y="170.0"/>
            <mxPoint x="740.0" y="170.0"/>
            <mxPoint x="740.0" y="390.0"/>
            <mxPoint x="720.0" y="390.0"/>
          </Array>
          <mxPoint as="targetPoint" x="720.0" y="420.0"/>
        </mxGeometry>
      </CommandControlLink>

      <!-- Link 20: GAIN3_out → SCOPE1_in2 (theta to scope in2) -->
      <ExplicitLink id="lnk_G3_SCOPE2" parent="0:2:0" source="GAIN3_out" target="SCOPE1_in2" style="" value="">
        <mxGeometry as="geometry">
          <mxPoint as="sourcePoint" x="500.0" y="440.0"/>
          <Array as="points">
            <mxPoint x="562.0" y="440.0"/>
            <mxPoint x="562.0" y="212.0"/>
            <mxPoint x="680.0" y="212.0"/>
          </Array>
          <mxPoint as="targetPoint" x="700.0" y="212.0"/>
        </mxGeometry>
      </ExplicitLink>

      <!-- diagnostic read -->
    </root>
  </mxGraphModel>
</XcosDiagram>