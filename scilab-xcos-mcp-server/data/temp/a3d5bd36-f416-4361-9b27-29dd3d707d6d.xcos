      <ControlPort id="ANIM1_ctrl" parent="ANIM1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ControlPort;align=center;verticalAlign=top;spacing=10.0" value=""/>
      <ExplicitInputPort id="ANIM1_in1" parent="ANIM1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>
      <ExplicitInputPort id="ANIM1_in2" parent="ANIM1" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>

      <!-- BARXY: bar chart of pendulum position (sin(theta) vs cos(theta)) -->
      <BasicBlock id="BAR1" parent="0:2:0" interfaceFunctionName="BARXY" blockType="d" dependsOnU="1" dependsOnT="0" simulationFunctionName="BARXY_sim" simulationFunctionType="SCILAB" style="BARXY">
        <ScilabString as="exprs" height="5" width="1">
          <data line="0" column="0" value="-1.5"/>
          <data line="1" column="0" value="1.5"/>
          <data line="2" column="0" value="-1.5"/>
          <data line="3" column="0" value="1.5"/>
          <data line="4" column="0" value="1"/>
        </ScilabString>
        <ScilabDouble as="realParameters" height="1" width="4">
          <data line="0" column="0" realPart="-1.5"/>
          <data line="0" column="1" realPart="1.5"/>
          <data line="0" column="2" realPart="-1.5"/>
          <data line="0" column="3" realPart="1.5"/>
        </ScilabDouble>
        <ScilabInteger as="integerParameters" height="1" width="1" intPrecision="sci_int32">
