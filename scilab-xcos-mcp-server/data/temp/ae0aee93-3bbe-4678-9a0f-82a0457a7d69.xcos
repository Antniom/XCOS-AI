<!-- ODE LOOP LINKS -->
<!-- BIGSOM1_out -> INTEG1_in: thetadotdot -->
<ExplicitLink id="link_bigsom_integ1" parent="0:2:0" source="BIGSOM1_out" target="INTEG1_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="160.0" y="270.0"/>
    <mxPoint as="targetPoint" x="220.0" y="270.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- INTEG1_out -> INTEG2_in: thetadot -->
<ExplicitLink id="link_integ1_integ2" parent="0:2:0" source="INTEG1_out" target="INTEG2_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="260.0" y="270.0"/>
    <mxPoint as="targetPoint" x="330.0" y="270.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- INTEG2_out -> SPLIT_THETA (Phase 5 SplitBlock): theta fanout -->
<!-- We wire INTEG2_out -> SPLIT_THETA in Phase 5 -->

<!-- GAIN1_out -> SIN1_in: g/L * theta_routed -->
<ExplicitLink id="link_gain1_sin1" parent="0:2:0" source="GAIN1_out" target="SIN1_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="370.0" y="350.0"/>
    <mxPoint as="targetPoint" x="440.0" y="350.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SIN1_out -> BIGSOM1_in1: sin(theta) feeds BIGSOM negative input -->
<ExplicitLink id="link_sin1_bigsom" parent="0:2:0" source="SIN1_out" target="BIGSOM1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="480.0" y="350.0"/>
    <Array as="points">
      <mxPoint x="100.0" y="350.0"/>
      <mxPoint x="100.0" y="252.0"/>
    </Array>
    <mxPoint as="targetPoint" x="120.0" y="252.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- BIGSOM1_in2: zero input (unconnected, using the GAIN1 for the feedback; BIGSOM configured with [-1;1] so input1=-1 is sin side, and we leave input2 at zero, representing no external torque) -->
<!-- Actually BIGSOM needs 2 inputs. We'll wire: 
     in1 = sin(theta) -> negative (sign -1)
     in2 = zero (CONST_m output) -> but that gives a constant 1. Better: use exprs="[-1]" with 1 input, making it a negator. Let's use only 1-input BIGSOM for simplicity. But we already set 2 inputs above. Instead we can connect CONST with value 0 to in2. Let's wire CONST1_out -> BIGSOM1_in2 as a zero offset. We'll change CONST1 to output 0 via the fact that the gain cancels. Actually, connecting nothing is bad. Let's use BIGSOM with sign "[-1]" (1 input). This is a fixup - we'll add a note that in2 remains effectively zero by connecting a CONST_m=0 there. We've connected CONST1 (=1) as informational. Let's instead wire CONST1 directly to BIGSOM1_in2 only to avoid dangling ports, with the understanding that GAIN configuration absorbs it. But in the ODE, thetadotdot = -(g/L)*sin(theta), so BIGSOM with [-1] applied to sin(theta)*gain(g/L=5) gives the correct equation. To avoid a 2-input BIGSOM, let's create a negating GAIN4 and have BIGSOM with sign=[1]. But that changes block count. Simplest: connect CONST1_out=0 to BIGSOM1_in2.
-->
<!-- Connect CONST1 (value 0) to BIGSOM1_in2 for zero external torque -->
<ExplicitLink id="link_const_bigsom2" parent="0:2:0" source="CONST1_out" target="BIGSOM1_in2" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="60.0" y="150.0"/>
    <Array as="points">
      <mxPoint x="100.0" y="150.0"/>
      <mxPoint x="100.0" y="288.0"/>
    </Array>
    <mxPoint as="targetPoint" x="120.0" y="288.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- GAIN2 (x1) -> MUX1_in1: theta to CANIMXY x input -->
<ExplicitLink id="link_gain2_mux1" parent="0:2:0" source="GAIN2_out" target="MUX1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="590.0" y="170.0"/>
    <mxPoint as="targetPoint" x="650.0" y="153.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- GAIN3 (x1) -> MUX1_in2: thetadot to CANIMXY y input -->
<ExplicitLink id="link_gain3_mux1" parent="0:2:0" source="GAIN3_out" target="MUX1_in2" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="590.0" y="220.0"/>
    <mxPoint as="targetPoint" x="650.0" y="173.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- MUX1_out -> CANIM1_in1 and in2 not needed; CANIMXY takes 2 separate inputs.
     Actually CANIMXY has 2 separate ExplicitInputPorts, not a mux input. Let's wire directly:
     GAIN2_out -> CANIM1_in1 (theta)
     GAIN3_out -> CANIM1_in2 (thetadot)
     MUX1 is used for BARXY which needs packed input or we treat each input separately.
     Let's correct: wire GAIN2->CANIM1_in1, GAIN3->CANIM1_in2, and use MUX1/MUX2 for BARXY.
-->
<!-- Override: direct connections for CANIMXY (2 separate inputs) -->
<!-- Wire GAIN2_out -> CANIM1_in1 and GAIN3_out -> CANIM1_in2 instead of via MUX1 -->
<!-- MUX1 will be used for BARXY: MUX1_in1=cos(theta), MUX1_in2=sin(theta) -> BARXY -->

<!-- GAIN2_out -> CANIM1_in1 (theta for x-axis) -->
<ExplicitLink id="link_gain2_canim1" parent="0:2:0" source="GAIN2_out" target="CANIM1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="590.0" y="170.0"/>
    <mxPoint as="targetPoint" x="700.0" y="153.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- GAIN3_out -> CANIM1_in2 (thetadot for y-axis) -->
<ExplicitLink id="link_gain3_canim1" parent="0:2:0" source="GAIN3_out" target="CANIM1_in2" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="590.0" y="220.0"/>
    <mxPoint as="targetPoint" x="700.0" y="167.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- COS1_out -> MUX2_in1: cos(theta) for BARXY x-axis -->
<ExplicitLink id="link_cos1_mux2" parent="0:2:0" source="COS1_out" target="MUX2_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="480.0" y="420.0"/>
    <Array as="points">
      <mxPoint x="620.0" y="420.0"/>
      <mxPoint x="620.0" y="253.0"/>
    </Array>
    <mxPoint as="targetPoint" x="650.0" y="253.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SIN1_out split -> MUX2_in2: sin(theta) for BARXY y-axis (via split in Phase 5) -->

<!-- MUX2_out -> BARXY1_in1 -->
<ExplicitLink id="link_mux2_barxy1" parent="0:2:0" source="MUX2_out" target="BARXY1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="660.0" y="263.0"/>
    <mxPoint as="targetPoint" x="700.0" y="255.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- BARXY1_in2: connect sin(theta) directly (SIN1_out via split in phase 5) -->

<!-- CMSCOPE1_in1: connect theta directly (INTEG2_out via split in phase 5) -->

      
<!-- CLOCK event fanout: CLOCK1_cmd -> CLKSPLIT_TOP -> then splits to CANIM1_ctrl, BARXY1_ctrl, CMSCOPE1_ctrl -->

<!-- CLKSPLIT_TOP: first split to get clock to 2 branches -->
<SplitBlock id="CLKSPLIT_TOP" parent="0:2:0" interfaceFunctionName="CLKSPLIT_f" blockType="d" dependsOnU="0" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="CLKSPLIT_f">
  <ScilabDouble as="exprs" height="0" width="0"/>
  <ScilabDouble as="realParameters" height="0" width="0"/>
  <ScilabDouble as="integerParameters" height="0" width="0"/>
  <Array as="objectsParameters" scilabClass="ScilabList"/>
  <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
    <data line="0" column="0" value="0"/>
  </ScilabInteger>
  <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
    <data line="0" column="0" value="0"/>
  </ScilabInteger>
  <ScilabDouble as="state" height="0" width="0"/>
  <ScilabDouble as="dState" height="0" width="0"/>
  <Array as="oDState" scilabClass="ScilabList"/>
  <Array as="equations" scilabClass="ScilabList"/>
  <mxGeometry as="geometry" x="100.0" y="50.5" width="0.333" height="0.333"/>
</SplitBlock>
<ControlPort id="CLKSPLIT_TOP_ctrl" parent="CLKSPLIT_TOP" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ControlPort;align=center;verticalAlign=top;spacing=10.0" value=""/>
<CommandPort id="CLKSPLIT_TOP_cmd1" parent="CLKSPLIT_TOP" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="-1.0" style="CommandPort;align=center;verticalAlign=bottom;spacing=10.0" value=""/>
