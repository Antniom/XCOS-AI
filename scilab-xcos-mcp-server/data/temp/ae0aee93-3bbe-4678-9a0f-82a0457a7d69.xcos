<ExplicitOutputPort id="SPLIT_SIN_out2" parent="SPLIT_SIN" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- === REWIRE LINKS using split blocks === -->

<!-- INTEG1_out -> SPLIT_THETADOT_in (replacing direct INTEG1->INTEG2 wire from phase 3) -->
<ExplicitLink id="link_integ1_splittdot" parent="0:2:0" source="INTEG1_out" target="SPLIT_THETADOT_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="260.0" y="270.0"/>
    <mxPoint as="targetPoint" x="290.0" y="270.5"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETADOT_out1 -> INTEG2_in: thetadot -> theta -->
<ExplicitLink id="link_splittdot_integ2" parent="0:2:0" source="SPLIT_THETADOT_out1" target="INTEG2_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="290.0" y="270.5"/>
    <mxPoint as="targetPoint" x="330.0" y="270.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETADOT_out2 -> GAIN3_in: thetadot -> CANIMXY y -->
<ExplicitLink id="link_splittdot_gain3" parent="0:2:0" source="SPLIT_THETADOT_out2" target="GAIN3_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="290.0" y="270.5"/>
    <Array as="points">
      <mxPoint x="290.0" y="220.0"/>
      <mxPoint x="550.0" y="220.0"/>
    </Array>
    <mxPoint as="targetPoint" x="550.0" y="220.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- INTEG2_out -> SPLIT_THETA_A_in: theta fanout -->
<ExplicitLink id="link_integ2_splittheta_a" parent="0:2:0" source="INTEG2_out" target="SPLIT_THETA_A_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="370.0" y="270.0"/>
    <mxPoint as="targetPoint" x="390.0" y="270.5"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_A_out1 -> GAIN1_in: theta -> g/L gain for feedback -->
<ExplicitLink id="link_splittheta_a_gain1" parent="0:2:0" source="SPLIT_THETA_A_out1" target="GAIN1_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="390.0" y="270.5"/>
    <Array as="points">
      <mxPoint x="390.0" y="350.0"/>
    </Array>
    <mxPoint as="targetPoint" x="330.0" y="350.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_A_out2 -> SPLIT_THETA_B_in: more fanout -->
<ExplicitLink id="link_splittheta_a_b" parent="0:2:0" source="SPLIT_THETA_A_out2" target="SPLIT_THETA_B_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="390.0" y="270.5"/>
    <mxPoint as="targetPoint" x="500.0" y="270.5"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_B_out1 -> GAIN2_in: theta -> CANIMXY x -->
<ExplicitLink id="link_splittheta_b_gain2" parent="0:2:0" source="SPLIT_THETA_B_out1" target="GAIN2_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="270.5"/>
    <Array as="points">
      <mxPoint x="500.0" y="170.0"/>
      <mxPoint x="550.0" y="170.0"/>
    </Array>
    <mxPoint as="targetPoint" x="550.0" y="170.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_B_out2 -> CMSCOPE1_in1: theta to scope -->
<ExplicitLink id="link_splittheta_b_cmscope" parent="0:2:0" source="SPLIT_THETA_B_out2" target="CMSCOPE1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="270.5"/>
    <Array as="points">
      <mxPoint x="680.0" y="270.5"/>
      <mxPoint x="680.0" y="360.0"/>
    </Array>
    <mxPoint as="targetPoint" x="700.0" y="360.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_A feeds COSBLK as well: need another split or use SPLIT_THETA_B for COS too -->
<!-- Route SPLIT_THETA_B -> COS1_in also (add an output3 is not possible on a 2-port split).
     Use SPLIT_THETA_B_out2 for both COS1 and CMSCOPE via another split.
     For simplicity: attach COS1 from SPLIT_THETA_A_out1 (replacing the GAIN1 path) is not possible.
     Best: use SPLIT_THETA_A_out1 -> GAIN1_in, add SPLIT for COS1 from GAIN1 output path is wrong.
     Let's attach COS1_in to SPLIT_THETA_B output by splitting SPLIT_THETA_B_out2 into CMSCOPE and COS1.
-->
<!-- SPLIT_THETA_C: further split of theta_B_out2 to COS1 and CMSCOPE1 -->
<SplitBlock id="SPLIT_THETA_C" parent="0:2:0" interfaceFunctionName="SPLIT_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="SPLIT_f">
  <ScilabDouble as="exprs" height="0" width="0"/>
  <ScilabDouble as="realParameters" height="0" width="0"/>
  <ScilabDouble as="integerParameters" height="0" width="0"/>
  <Array as="objectsParameters" scilabClass="ScilabList"/>
  <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32">
    <data line="0" column="0" value="0"/>
  </ScilabInteger>
  <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32">
    <data line="0" column="0" value="0"/>
  </ScilabInteger>
  <ScilabDouble as="state" height="0" width="0"/>
  <ScilabDouble as="dState" height="0" width="0"/>
  <Array as="oDState" scilabClass="ScilabList"/>
  <Array as="equations" scilabClass="ScilabList"/>
  <mxGeometry as="geometry" x="610.0" y="360.5" width="0.333" height="0.333"/>
</SplitBlock>
<ExplicitInputPort id="SPLIT_THETA_C_in" parent="SPLIT_THETA_C" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>
<ExplicitOutputPort id="SPLIT_THETA_C_out1" parent="SPLIT_THETA_C" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>
<ExplicitOutputPort id="SPLIT_THETA_C_out2" parent="SPLIT_THETA_C" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- Re-route SPLIT_THETA_B_out2 -> SPLIT_THETA_C (replaces direct CMSCOPE link) -->
<ExplicitLink id="link_splittheta_b_c" parent="0:2:0" source="SPLIT_THETA_B_out2" target="SPLIT_THETA_C_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="270.5"/>
    <Array as="points">
      <mxPoint x="500.0" y="360.5"/>
    </Array>
    <mxPoint as="targetPoint" x="610.0" y="360.5"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_C_out1 -> COS1_in -->
<ExplicitLink id="link_splittheta_c_cos1" parent="0:2:0" source="SPLIT_THETA_C_out1" target="COS1_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="610.0" y="360.5"/>
    <Array as="points">
      <mxPoint x="440.0" y="420.0"/>
    </Array>
    <mxPoint as="targetPoint" x="440.0" y="420.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_THETA_C_out2 -> CMSCOPE1_in1 -->
<ExplicitLink id="link_splittheta_c_cmscope" parent="0:2:0" source="SPLIT_THETA_C_out2" target="CMSCOPE1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="610.0" y="360.5"/>
    <Array as="points">
      <mxPoint x="680.0" y="360.5"/>
    </Array>
    <mxPoint as="targetPoint" x="700.0" y="360.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SIN1_out -> SPLIT_SIN_in -->
<ExplicitLink id="link_sin1_splsin" parent="0:2:0" source="SIN1_out" target="SPLIT_SIN_in" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="480.0" y="350.0"/>
    <mxPoint as="targetPoint" x="500.0" y="350.5"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_SIN_out1 -> BIGSOM1_in1: sin(theta) to ODE feedback (replace old direct sin->bigsom link) -->
<ExplicitLink id="link_splsin_bigsom" parent="0:2:0" source="SPLIT_SIN_out1" target="BIGSOM1_in1" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="350.5"/>
    <Array as="points">
      <mxPoint x="100.0" y="350.5"/>
      <mxPoint x="100.0" y="252.0"/>
    </Array>
    <mxPoint as="targetPoint" x="120.0" y="252.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- SPLIT_SIN_out2 -> MUX2_in2: sin(theta) to BARXY y-axis -->
<ExplicitLink id="link_splsin_mux2" parent="0:2:0" source="SPLIT_SIN_out2" target="MUX2_in2" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="350.5"/>
    <Array as="points">
      <mxPoint x="500.0" y="273.0"/>
    </Array>
    <mxPoint as="targetPoint" x="650.0" y="273.0"/>
  </mxGeometry>
</ExplicitLink>

<!-- BARXY1_in2: connect thetadot (SPLIT_THETADOT_out2 already to GAIN3; need separate branch).
     BARXY wants x=cos(theta), y=sin(theta) via MUX2 and in2.
     Actually BARXY takes 2 inputs: in1=x values, in2=y values.
     MUX2_out -> BARXY1_in1 is done. BARXY1_in2 should be y values (heights).
     Let's use sin(theta) directly: SPLIT_SIN_out2 -> BARXY1_in2 (replacing MUX2 for in2).
     Wait, in Phase 3 we wired MUX2_out -> BARXY1_in1. MUX2 combines cos and sin, outputting a 2-vector.
     BARXY in1 is the x positions vector and in2 is the y positions vector.
     Actually for a pendulum BARXY typically shows position vector, so:
     in1 = [sin(theta)] (x position of bob), in2 = [-cos(theta)] (y position).
     But let's keep it simple: in1 = cos(theta) (from MUX2_in1=COS1_out), in2 = sin(theta) (SPLIT_SIN_out2).
     BARXY1_in1 was connected to MUX2_out which is a 2-vector. That's wrong.
     Let's connect: COS1_out (already via MUX2_in1) directly to BARXY1_in1, and SPLIT_SIN_out2 -> BARXY1_in2.
     Actually, COS1_out -> MUX2_in1 is only already planned. Let's fix:
     remove MUX2 from this path and wire COS1_out directly to BARXY1_in1.
-->
<!-- MUX1 still available for BARXY x (cos(theta)), MUX2 not used for BARXY.
     Wire COS1_out directly to BARXY1_in1 via the existing MUX2 path (MUX2 out->BARXY1_in1).
     Wire SPLIT_SIN_out2 -> BARXY1_in2. -->
<ExplicitLink id="link_splsin_barxy2" parent="0:2:0" source="SPLIT_SIN_out2" target="BARXY1_in2" style="" value="">
  <mxGeometry as="geometry">
    <mxPoint as="sourcePoint" x="500.0" y="350.5"/>
    <Array as="points">
      <mxPoint x="630.0" y="350.5"/>
      <mxPoint x="630.0" y="263.0"/>
      <mxPoint x="690.0" y="263.0"/>
    </Array>
    <mxPoint as="targetPoint" x="700.0" y="263.0"/>
  </mxGeometry>
</ExplicitLink>

    </root>
  </mxGraphModel>
</XcosDiagram>