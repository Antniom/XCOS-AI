<ExplicitOutputPort id="SPLIT_THETA_A_out2" parent="SPLIT_THETA_A" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- SPLIT_THETA_B: second split for theta for GAIN2 and CMSCOPE1 and COSBLK fanout -->
<SplitBlock id="SPLIT_THETA_B" parent="0:2:0" interfaceFunctionName="SPLIT_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="SPLIT_f">
