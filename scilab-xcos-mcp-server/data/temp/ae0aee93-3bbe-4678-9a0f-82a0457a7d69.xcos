<ExplicitOutputPort id="SPLIT_THETA_B_out2" parent="SPLIT_THETA_B" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- SPLIT_THETADOT: fanout of thetadot (INTEG1_out) to INTEG2 (already wired) + GAIN3 -->
<SplitBlock id="SPLIT_THETADOT" parent="0:2:0" interfaceFunctionName="SPLIT_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="SPLIT_f">
