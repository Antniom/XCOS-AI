<ExplicitOutputPort id="GAIN1_out" parent="GAIN1" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- SINBLK_f: computes sin(g/L * theta) — NOTE: this is non-standard; correct flow is g/L * sin(theta).
     So the order must be: theta -> SIN -> GAIN(5) -> BIGSOM(-1).
     Place SINBLK before GAIN: theta -> SIN -> GAIN(5) -> BIGSOM(-1) = -(g/L)*sin(theta) = thetadotdot. -->
<BasicBlock id="SIN1" parent="0:2:0" interfaceFunctionName="SINBLK_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="sinblk" simulationFunctionType="DEFAULT" style="SINBLK_f">
