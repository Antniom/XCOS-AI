<!-- ===== ALL EXPLICIT DATA LINKS =====
  Each source port drives exactly ONE target. All fanouts go through SplitBlocks.
  
  Full connection map:
  BIGSOM1_out      -> INTEG1_in
  INTEG1_out       -> SPL_TDOT_in
  SPL_TDOT_out1    -> INTEG2_in
  SPL_TDOT_out2    -> GAIN3_in
  INTEG2_out       -> SPL_TH_A_in
  SPL_TH_A_out1    -> SIN1_in
  SPL_TH_A_out2    -> SPL_TH_B_in
  SPL_TH_B_out1    -> GAIN2_in
  SPL_TH_B_out2    -> SPL_TH_C_in
  SPL_TH_C_out1    -> COS1_in
  SPL_TH_C_out2    -> CMSCOPE1_in1
  SIN1_out         -> SPL_SIN_in
  SPL_SIN_out1     -> GAIN1_in
  SPL_SIN_out2     -> BARXY1_in2
  GAIN1_out        -> BIGSOM1_in1
  GAIN2_out        -> CANIM1_in1
  GAIN3_out        -> CANIM1_in2
  COS1_out         -> BARXY1_in1
-->

