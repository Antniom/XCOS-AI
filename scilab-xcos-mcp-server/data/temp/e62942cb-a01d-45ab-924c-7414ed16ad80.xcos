<!-- Signal fanout plan:
  INTEG1_out (thetadot) fans to: INTEG2_in + GAIN3_in  => SPLIT_THETADOT
  INTEG2_out (theta) fans to: SIN1_in + GAIN2_in + COS1_in  => SPLIT_THETA_A (->SIN1, ->SPLIT_THETA_B), SPLIT_THETA_B (->GAIN2, ->COS1)
  SIN1_out fans to: GAIN1_in (only one target, no split needed)
  GAIN1_out (g/L*sin(theta)) fans to: BIGSOM1_in1 (only one target, no split needed)
  GAIN2_out -> CANIM1_in1 (one target)
  GAIN3_out -> CANIM1_in2 (one target)
  COS1_out -> BARXY1_in1 (one target)
  SIN1_out -> BARXY1_in2 — BUT SIN1_out already goes to GAIN1_in! Need SPLIT_SIN.
  Actually: SIN1_out fans to GAIN1_in + BARXY1_in2 => SPLIT_SIN
  Also: CMSCOPE1_in1 needs theta -> need 3rd output from theta fanout => SPLIT_THETA_B fans to GAIN2_in + SPLIT_THETA_C, SPLIT_THETA_C fans to COS1_in + CMSCOPE1_in1
-->

<!-- SPLIT_THETADOT: INTEG1_out -> {INTEG2_in, GAIN3_in} -->
<SplitBlock id="SPL_TDOT" parent="0:2:0" interfaceFunctionName="SPLIT_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="split" simulationFunctionType="DEFAULT" style="SPLIT_f">
  <ScilabDouble as="exprs" height="0" width="0"/>
  <ScilabDouble as="realParameters" height="0" width="0"/>
  <ScilabDouble as="integerParameters" height="0" width="0"/>
  <Array as="objectsParameters" scilabClass="ScilabList"/>
  <ScilabInteger as="nbZerosCrossing" height="1" width="1" intPrecision="sci_int32"><data line="0" column="0" value="0"/></ScilabInteger>
  <ScilabInteger as="nmode" height="1" width="1" intPrecision="sci_int32"><data line="0" column="0" value="0"/></ScilabInteger>
  <ScilabDouble as="state" height="0" width="0"/>
  <ScilabDouble as="dState" height="0" width="0"/>
  <Array as="oDState" scilabClass="ScilabList"/>
  <Array as="equations" scilabClass="ScilabList"/>
  <mxGeometry as="geometry" x="290.0" y="270.5" width="0.333" height="0.333"/>
</SplitBlock>
<ExplicitInputPort id="SPL_TDOT_in" parent="SPL_TDOT" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitInputPort;align=left;verticalAlign=middle;spacing=10.0" value=""/>
<ExplicitOutputPort id="SPL_TDOT_out1" parent="SPL_TDOT" ordering="1" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>
<ExplicitOutputPort id="SPL_TDOT_out2" parent="SPL_TDOT" ordering="2" dataType="REAL_MATRIX" dataColumns="1" dataLines="1" initialState="0.0" style="ExplicitOutputPort;align=right;verticalAlign=middle;spacing=10.0" value=""/>

<!-- SPLIT_THETA_A: INTEG2_out -> {SIN1_in, SPLIT_THETA_B_in} -->
