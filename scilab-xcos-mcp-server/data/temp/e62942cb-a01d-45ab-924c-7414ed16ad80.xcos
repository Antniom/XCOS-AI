<!-- GAIN_f: gain = 5 = g/L = 10/2, applied before SINBLK so flow is: theta->GAIN(5)->SIN->BIGSOM(-1) -->
<BasicBlock id="GAIN1" parent="0:2:0" interfaceFunctionName="GAIN_f" blockType="c" dependsOnU="1" dependsOnT="0" simulationFunctionName="gain" simulationFunctionType="DEFAULT" style="GAIN_f">
  <ScilabString as="exprs" height="3" width="1">
    <data line="0" column="0" value="5"/>
    <data line="1" column="0" value="1"/>
    <data line="2" column="0" value="1"/>
  </ScilabString>
